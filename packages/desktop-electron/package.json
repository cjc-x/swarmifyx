{
  "name": "@abacus/desktop-electron",
  "version": "0.0.1",
  "private": true,
  "description": "Windows-first Electron wrapper for the Abacus control plane",
  "author": "Abacus AI",
  "homepage": "https://github.com/abacus-lab/abacus",
  "type": "module",
  "main": "dist/main.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs --profile dev",
    "build:release": "node scripts/build.mjs --profile release",
    "typecheck": "tsc --noEmit",
    "prepare:stage": "node scripts/prepare-stage.mjs",
    "pack": "node scripts/prepare-stage.mjs && electron-builder --config electron-builder.yml --dir --win",
    "dist": "node scripts/prepare-stage.mjs && electron-builder --config electron-builder.yml",
    "dist:win": "node scripts/prepare-stage.mjs && electron-builder --config electron-builder.yml --win"
  },
  "dependencies": {
    "@abacus/server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "electron": "41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.0",
    "javascript-obfuscator": "^4.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
