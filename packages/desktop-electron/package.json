{
  "name": "@chopsticks/desktop-electron",
  "version": "0.0.1",
  "private": true,
  "description": "Windows-first Electron wrapper for the Chopsticks control plane",
  "author": "Chopsticks AI",
  "homepage": "https://github.com/chopsticksai/chopsticks",
  "type": "module",
  "main": "dist/main.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepare:stage": "node scripts/prepare-stage.mjs",
    "pack": "node scripts/prepare-stage.mjs && electron-builder --config electron-builder.yml --dir --win",
    "dist": "node scripts/prepare-stage.mjs && electron-builder --config electron-builder.yml",
    "dist:win": "node scripts/prepare-stage.mjs && electron-builder --config electron-builder.yml --win"
  },
  "dependencies": {
    "@chopsticks/server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
